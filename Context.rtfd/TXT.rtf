\f1\b\fs32\fsmilli16380 \cf2 \cb4 The Problem It Solves\cb1 \
\pard\pardeftab720\partightenfactor0

\f0\b0\fs28 \cf2 \cb4 Your model was trained on historical data. But data changes over time \'97 customer behavior shifts, new policies appear, economic conditions change.\'a0
\f1\b Drift detection
\f0\b0 \'a0asks: "Is the data coming in today still similar enough to what the model was trained on?"\cb1 \
\cb4 If not \uc0\u8594  the model's predictions are unreliable \u8594  time to retrain.\cb1 \
\pard\pardeftab720\sa327\partightenfactor0

\f1\b\fs32\fsmilli16380 \cf2 \cb4 Three Statistical Tests\cb1 \
\pard\pardeftab720\partightenfactor0

\fs28 \cf2 \cb4 1. PSI (Population Stability Index)
\f0\b0 \'a0\'97 the primary metric\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls33\ilvl0\cf2 \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Compares the\'a0
\f4\i distribution shape
\f0\i0 \'a0between reference (training) data and current data\cb1 \
\ls33\ilvl0\cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 For numeric features: bins data into quantiles, compares proportions per bin\cb1 \
\ls33\ilvl0\cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 For categorical features: compares category proportions directly\cb1 \
\ls33\ilvl0\cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Formula:\'a0
\f3\fs25\fsmilli12600 \cb14 \uc0\u931  (current% - reference%) \'d7 ln(current% / reference%)
\f0\fs28 \cb1 \
\ls33\ilvl0\cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Thresholds:\cb1 \
\pard\tx940\tx1440\pardeftab720\li1440\fi-1440\partightenfactor0
\ls33\ilvl1
\f1\b \cf2 \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u9702 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 < 0.1
\f0\b0 \'a0\uc0\u8594  No drift, you're fine\cb1 \
\ls33\ilvl1
\f1\b \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u9702 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 0.1\'960.25
\f0\b0 \'a0\uc0\u8594  Moderate drift, keep watching\cb1 \
\ls33\ilvl1
\f1\b \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u9702 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 > 0.25
\f0\b0 \'a0\uc0\u8594  Significant drift, consider retraining\cb1 \
\pard\pardeftab720\partightenfactor0

\f1\b \cf2 \cb4 2. KS Test (Kolmogorov-Smirnov)
\f0\b0 \'a0\'97 for numeric features\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls34\ilvl0\cf2 \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Tests whether two samples come from the same distribution\cb1 \
\ls34\ilvl0\cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Returns a p-value:\'a0
\f1\b < 0.05
\f0\b0 \'a0means statistically significant drift\cb1 \
\ls34\ilvl0\cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Used as a\'a0
\f4\i secondary check
\f0\i0 \'a0when PSI is in the moderate zone\cb1 \
\pard\pardeftab720\partightenfactor0

\f1\b \cf2 \cb4 3. Chi-squared Test
\f0\b0 \'a0\'97 for categorical features\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls35\ilvl0\cf2 \cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Same idea as KS but for categories (contingency table approach)\cb1 \
\ls35\ilvl0\cb4 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 p-value\'a0
\f1\b < 0.05
\f0\b0 \'a0= significant drift\cb1 \
\pard\pardeftab720\sa327\partightenfactor0

\f1\b\fs32\fsmilli16380 \cf2 \cb4 The Classification Logic\cb1 \
\pard\pardeftab720\partightenfactor0

\f3\b0\fs24 \cf2 \cb14 PSI > 0.25                    \uc0\u8594  HIGH drift (alarm)\
PSI 0.1\'960.25 + p-value < 0.05 \uc0\u8594  MODERATE drift (watch)  \
PSI 0.1\'960.25 + p-value > 0.05 \uc0\u8594  LOW drift (eh, probably fine)\
PSI < 0.1                     \uc0\u8594  NONE\
\pard\pardeftab720\sa327\partightenfactor0

\f1\b\fs32\fsmilli16380 \cf2 \cb4 What It Produces\cb1 \
